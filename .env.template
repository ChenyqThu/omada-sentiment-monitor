# =============================================================================
# Omada 舆情监控系统 - 环境变量配置模板
# 请复制此文件为 .env 并填写相应的配置值
# =============================================================================

# =============================================================================
# Reddit API 配置
# 获取方式: https://www.reddit.com/prefs/apps
# =============================================================================
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=omada-sentiment-monitor:v1.0.0
REDDIT_RATE_LIMIT_CALLS=100
REDDIT_RATE_LIMIT_PERIOD=60

# =============================================================================
# Azure Text Analytics 配置（可选，如果使用 Azure 分析器）
# 获取方式: https://portal.azure.com
# =============================================================================
AZURE_TEXT_ANALYTICS_KEY=your_azure_key
AZURE_TEXT_ANALYTICS_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AZURE_API_VERSION=v3.1
AZURE_MAX_RETRIES=3
AZURE_TIMEOUT=30

# =============================================================================
# OpenAI API 配置（推荐，支持第三方兼容 API）
# 获取方式: https://platform.openai.com/api-keys
# =============================================================================
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_MAX_TOKENS=150
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_RETRIES=3
OPENAI_TIMEOUT=30

# =============================================================================
# Notion API 配置
# 获取方式: https://www.notion.so/my-integrations
# =============================================================================
NOTION_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_database_id
NOTION_API_VERSION=2022-06-28
NOTION_MAX_RETRIES=3
NOTION_TIMEOUT=30
NOTION_REQUIRED=false

# =============================================================================
# 邮件配置（用于预警通知）
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true
EMAIL_RECIPIENTS=alert1@company.com,alert2@company.com

# =============================================================================
# 监控配置
# =============================================================================
TARGET_SUBREDDITS=homenetworking,networking,sysadmin,TPLINK
PRIMARY_KEYWORDS=omada,tp-link,tplink,access point,archer,deco,eap
SECONDARY_KEYWORDS=mesh network,wifi 6,access point,router
COMPETITOR_KEYWORDS=ubiquiti,unifi,aruba,cisco
CHECK_INTERVAL=300
MAX_POSTS_PER_SUBREDDIT=25
RELEVANCE_THRESHOLD=0.3

# =============================================================================
# AI 分析配置
# =============================================================================
AI_ANALYZER_TYPE=local
AI_ANALYSIS_ENABLED=true
AI_ANALYSIS_REQUIRED=false
ENABLE_SENTIMENT_ANALYSIS=true
ENABLE_KEY_PHRASES=true
ENABLE_TOPIC_CLASSIFICATION=true
AI_BATCH_SIZE=10

# Notion AI 列名配置（如果使用 Notion AI）
NOTION_SENTIMENT_COLUMN=AI情感分析
NOTION_SUMMARY_COLUMN=AI摘要
NOTION_KEYWORDS_COLUMN=AI关键词

# =============================================================================
# 预警配置
# =============================================================================
ALERTS_ENABLED=true
CRITICAL_SENTIMENT_THRESHOLD=-0.7
HIGH_SENTIMENT_THRESHOLD=-0.5
INFLUENCE_SCORE_THRESHOLD=80
NEGATIVE_MENTIONS_1H_THRESHOLD=5

# =============================================================================
# 系统配置
# =============================================================================
LOG_LEVEL=INFO
DEBUG_MODE=false
TEST_MODE=false
DATA_RETENTION_DAYS=30
CACHE_ENABLED=true
CACHE_TTL=3600
