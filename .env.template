# =============================================================================
# Omada 舆情监控系统 - 环境变量配置模板
# 请复制此文件为 .env 并填写相应的配置值
# =============================================================================

# =============================================================================
# Reddit API 配置
# 获取方式: https://www.reddit.com/prefs/apps
# =============================================================================
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=omada-sentiment-monitor:v1.0.0
REDDIT_RATE_LIMIT_CALLS=100
REDDIT_RATE_LIMIT_PERIOD=60

# =============================================================================
# AI 过滤配置 (Gemini 或 OpenAI 兼容)
# =============================================================================
AI_FILTER_PROVIDER=gemini
AI_FILTER_API_KEY=your_api_key
AI_FILTER_MODEL=gemini-2.0-flash-lite
# AI_FILTER_BASE_URL=          # OpenAI 兼容提供商的 base URL
AI_FILTER_RELEVANCE_THRESHOLD=0.4
AI_FILTER_BATCH_SIZE=15

# =============================================================================
# Notion API 配置
# 获取方式: https://www.notion.so/my-integrations
# =============================================================================
NOTION_TOKEN=your_notion_integration_token
NOTION_DATABASE_ID=your_database_id
NOTION_KOL_DATABASE_ID=your_kol_database_id
NOTION_API_VERSION=2022-06-28
NOTION_MAX_RETRIES=3
NOTION_TIMEOUT=30
NOTION_REQUIRED=false

# =============================================================================
# 邮件配置（用于预警通知，可选）
# =============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_USE_TLS=true
EMAIL_RECIPIENTS=alert1@company.com,alert2@company.com

# =============================================================================
# 监控配置
# =============================================================================
TARGET_SUBREDDITS=homenetworking,networking,sysadmin,TPLINK
PRIMARY_KEYWORDS=omada,tp-link,tplink,access point,archer,deco,eap
SECONDARY_KEYWORDS=mesh network,wifi 6,access point,router
COMPETITOR_KEYWORDS=ubiquiti,unifi,aruba,cisco
CHECK_INTERVAL=300
MAX_POSTS_PER_SUBREDDIT=25
RELEVANCE_THRESHOLD=0.3
COLLECTOR_TYPE=json

# =============================================================================
# 系统配置
# =============================================================================
LOG_LEVEL=INFO
DEBUG_MODE=false
TEST_MODE=false
DATA_RETENTION_DAYS=30
DB_PATH=data/omada_monitor.db
